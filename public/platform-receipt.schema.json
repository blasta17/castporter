{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cvp.example/schemas/platform-receipt-0.1.json",
  "title": "CVP Platform Receipt",
  "type": "object",
  "required": ["protocol", "operation", "platform", "canonical_id", "completed_at"],
  "properties": {
    "protocol": { "const": "cvp/0.1" },
    "operation": { "enum": ["publish", "update", "sync", "unpublish", "delete"] },
    "mode": { "enum": ["mock", "live"] },
    "platform": { "type": "string" },
    "canonical_id": { "type": "string" },
    "external_id": { "type": ["string", "null"] },
    "external_url": { "type": ["string", "null"] },
    "completed_at": { "type": "string", "format": "date-time" },
    "digest": { "type": "string" },
    "details": { "type": "object" }
  },
  "additionalProperties": true
}
