# Runtime
NODE_ENV=production
CVP_DATA_DIR=/data
NEXT_PUBLIC_APP_URL=http://localhost:3080
APP_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
DEMO_MODE=true
MAX_UPLOAD_BYTES=5368709120

# YouTube OAuth (optional, for live publishing)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3080/api/oauth/youtube/callback

# Default publishing mode: mock or live
CVP_PUBLISH_MODE=mock
